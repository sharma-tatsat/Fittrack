import { create } from 'zustand'
import { persist } from 'zustand/middleware'

// Types
export interface Exercise {
  id: string
  name: string
  muscleGroup: MuscleGroup
  icon: string
  difficulty: 'beginner' | 'intermediate' | 'advanced'
  isCustom: boolean
}

export type MuscleGroup = 'chest' | 'back' | 'legs' | 'shoulders' | 'arms' | 'core'

export interface WorkoutLog {
  id: string
  exerciseId: string
  weight: number
  reps: number
  sets: number
  date: string
}

export interface PersonalRecord {
  exerciseId: string
  maxWeight: number
  date: string
}

export interface TrainingDay {
  day: string
  exercises: string[] // exercise IDs
}

export interface TrainingPlan {
  id: string
  name: string
  days: TrainingDay[]
}

export interface CheckIn {
  date: string
  completed: boolean
}

export interface User {
  name: string
  email: string
}

// Default exercises database
const defaultExercises: Exercise[] = [
  // Chest
  { id: 'bench-press', name: 'Bench Press', muscleGroup: 'chest', icon: 'Dumbbell', difficulty: 'intermediate', isCustom: false },
  { id: 'incline-press', name: 'Incline Press', muscleGroup: 'chest', icon: 'Dumbbell', difficulty: 'intermediate', isCustom: false },
  { id: 'cable-fly', name: 'Cable Fly', muscleGroup: 'chest', icon: 'Cable', difficulty: 'beginner', isCustom: false },
  { id: 'dumbbell-fly', name: 'Dumbbell Fly', muscleGroup: 'chest', icon: 'Dumbbell', difficulty: 'beginner', isCustom: false },
  { id: 'push-ups', name: 'Push Ups', muscleGroup: 'chest', icon: 'User', difficulty: 'beginner', isCustom: false },
  
  // Back
  { id: 'pull-ups', name: 'Pull Ups', muscleGroup: 'back', icon: 'ArrowUp', difficulty: 'intermediate', isCustom: false },
  { id: 'lat-pulldown', name: 'Lat Pulldown', muscleGroup: 'back', icon: 'ArrowDown', difficulty: 'beginner', isCustom: false },
  { id: 'deadlift', name: 'Deadlift', muscleGroup: 'back', icon: 'Dumbbell', difficulty: 'advanced', isCustom: false },
  { id: 'barbell-rows', name: 'Barbell Rows', muscleGroup: 'back', icon: 'Dumbbell', difficulty: 'intermediate', isCustom: false },
  { id: 'cable-rows', name: 'Cable Rows', muscleGroup: 'back', icon: 'Cable', difficulty: 'beginner', isCustom: false },
  
  // Legs
  { id: 'squats', name: 'Squats', muscleGroup: 'legs', icon: 'Dumbbell', difficulty: 'intermediate', isCustom: false },
  { id: 'leg-press', name: 'Leg Press', muscleGroup: 'legs', icon: 'Square', difficulty: 'beginner', isCustom: false },
  { id: 'lunges', name: 'Lunges', muscleGroup: 'legs', icon: 'Footprints', difficulty: 'beginner', isCustom: false },
  { id: 'leg-extensions', name: 'Leg Extensions', muscleGroup: 'legs', icon: 'Zap', difficulty: 'beginner', isCustom: false },
  { id: 'leg-curls', name: 'Leg Curls', muscleGroup: 'legs', icon: 'Zap', difficulty: 'beginner', isCustom: false },
  { id: 'calf-raises', name: 'Calf Raises', muscleGroup: 'legs', icon: 'ArrowUp', difficulty: 'beginner', isCustom: false },
  
  // Shoulders
  { id: 'overhead-press', name: 'Overhead Press', muscleGroup: 'shoulders', icon: 'ArrowUp', difficulty: 'intermediate', isCustom: false },
  { id: 'lateral-raises', name: 'Lateral Raises', muscleGroup: 'shoulders', icon: 'Expand', difficulty: 'beginner', isCustom: false },
  { id: 'front-raises', name: 'Front Raises', muscleGroup: 'shoulders', icon: 'ArrowUp', difficulty: 'beginner', isCustom: false },
  { id: 'rear-delt-fly', name: 'Rear Delt Fly', muscleGroup: 'shoulders', icon: 'Expand', difficulty: 'beginner', isCustom: false },
  
